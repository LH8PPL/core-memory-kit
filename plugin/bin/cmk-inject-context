#!/usr/bin/env bash
# cmk-inject-context — SessionStart hook (Task 18 real handler).
#
# hooks.json invokes this via `bash "${CLAUDE_PLUGIN_ROOT}/bin/cmk-inject-context"`,
# so the entrypoint must be a bash script. The actual handler lives in
# the sibling .mjs file (so we get real ES-module support + a clean
# import of packages/cli/src/inject-context.mjs); this wrapper just
# resolves its own directory and execs node against the sibling.

script_dir="$(cd "$(dirname "$0")" && pwd)"
exec node "${script_dir}/cmk-inject-context.mjs"
