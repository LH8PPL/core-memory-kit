#!/usr/bin/env bash
# cmk-compress-session — SessionEnd hook (Task 22 real handler).
#
# hooks.json invokes this via `bash "${CLAUDE_PLUGIN_ROOT}/bin/cmk-compress-session"`,
# so the entrypoint must be a bash script. The actual handler lives in
# the sibling .mjs file (same pattern as cmk-capture-prompt, cmk-inject-context).

script_dir="$(cd "$(dirname "$0")" && pwd)"
exec node "${script_dir}/cmk-compress-session.mjs"
