#!/usr/bin/env bash
# cmk-capture-turn — Stop hook (Task 21 real handler).
#
# hooks.json invokes this via `bash "${CLAUDE_PLUGIN_ROOT}/bin/cmk-capture-turn"`.
# Same bash-wrapper-then-exec-node pattern as the other real handlers.
# The node handler honors the stop_hook_active recursion guard, appends
# the assistant turn (privacy-sanitized) to the daily transcript, and
# spawns a detached auto-extract subagent (Task 23 fills it in).

script_dir="$(cd "$(dirname "$0")" && pwd)"
exec node "${script_dir}/cmk-capture-turn.mjs"
