node_modules/

# Coverage reports (generated by `npm run test:coverage` / CI)
coverage/
*.lcov

# Milvus stack volumes (if anyone runs the compose file inside this repo)
template/milvus-deploy/volumes/
plugin/milvus-deploy-template/volumes/

# Logs from local testing
*.log
.extract-*.tmp

# Per-run logs from `npm run stress` (scripts/stress-test.mjs).
# Captures child stdout+stderr per iteration; never committed.
.stress-logs/

# Always-on vitest json result log (every `npm test` / `test:file` run;
# D-68). Diagnostic only, never committed.
.test-logs/

# canonicalize parity scratch dumps (Task 5)
/tmp-parity-*.json

# Task 40 install-matrix smoke-test artifact (local-only; CI uploads to GHA artifacts)
install-matrix-checksum.json

# Task 42 B1 fix: packages/cli/template/ is generated at publish time by
# scripts/prepublish-copy-template.mjs from the canonical template/ at
# repo root. Don't commit the generated copy.
packages/cli/template/
context/.index/

*.tgz
.bench-logs/

# claude-memory-kit:gitignore:start v0.4.0
# claude-memory-kit — added by `cmk install`. Do not edit by hand;
# `cmk install` refreshes these lines idempotently. Remove via
# `cmk uninstall`.

# Local-tier (per-machine, never committed)
context.local/

# SQLite + FTS5 read cache (regenerable from markdown)
context/.index/

# Run-time locks + transient state
context/.locks/

# Diagnostic NDJSON logs (observability only; carry raw turn excerpts —
# e.g. discarded-low-trust traces — that are NOT secret-screened, so they
# must never be committed). The durable memory lives in the scratchpads +
# fact files, not these logs.
context/sessions/*.extract.log

# Transcript-extraction temp buffer. capture-turn writes
# context/transcripts/.extract-<ts>.tmp as the turn buffer for the detached
# auto-extract child, which consumes + deletes it. Gitignored so a crash-orphaned
# partial (raw, un-screened turn content) never travels with `git clone`.
context/transcripts/.extract-*.tmp
# claude-memory-kit:gitignore:end

# Public-repo dogfood deviation (Task 52, D-108): this repo is PUBLIC, so the
# raw conversation surfaces stay machine-local — transcripts + session logs
# carry dev-conversation content (name-privacy class). The kit's default in a
# normal project is to COMMIT these; the curated tiers (MEMORY.md, SOUL.md,
# context/memory/) stay committed here as designed.
context/transcripts/
context/sessions/
packages/cli/context/

# Logo design scratch files (the shippable assets live in docs/public/assets/)
docs/public/*.html
docs/public/A _ Restore.png
*.stackdump
